---
/**
 * OhmsLawCalculator — Interactive calculator for V = I × R.
 * User fills any two fields to calculate the third.
 * Concept colors: Voltage (red), Current (blue), Resistance (orange).
 */
---

<div class="ohms-calculator my-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5">
  <noscript>
    <div class="space-y-3 text-sm">
      <h3 class="text-lg font-bold text-[var(--color-text)]">Ohm's Law Formulas</h3>
      <ul class="list-disc space-y-1 pl-5 text-[var(--color-text-muted)]">
        <li><strong class="text-red-600">V</strong> = <strong class="text-blue-600">I</strong> × <strong class="text-orange-500">R</strong> — Voltage equals Current times Resistance</li>
        <li><strong class="text-blue-600">I</strong> = <strong class="text-red-600">V</strong> ÷ <strong class="text-orange-500">R</strong> — Current equals Voltage divided by Resistance</li>
        <li><strong class="text-orange-500">R</strong> = <strong class="text-red-600">V</strong> ÷ <strong class="text-blue-600">I</strong> — Resistance equals Voltage divided by Current</li>
      </ul>
      <p class="text-[var(--color-text-muted)]"><strong>Example:</strong> If V = 12V and R = 6Ω, then I = 12 ÷ 6 = <strong class="text-blue-600">2A</strong></p>
    </div>
  </noscript>

  <form id="ohms-calc-form" class="ohms-calc-js space-y-4" novalidate>
    <fieldset class="space-y-3">
      <legend class="text-lg font-bold text-[var(--color-text)]">⚡ Ohm's Law Calculator</legend>
      <p class="text-sm text-[var(--color-text-muted)]">Fill in any two values and click Calculate.</p>

      <div class="grid gap-3 sm:grid-cols-3">
        <div>
          <label for="ohm-voltage" class="mb-1 block text-sm font-semibold text-red-600 dark:text-red-400">
            Voltage (V)
          </label>
          <input
            type="number"
            id="ohm-voltage"
            name="voltage"
            min="0"
            step="any"
            placeholder="e.g. 12"
            class="w-full rounded-lg border border-red-300 bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-red-400"
          />
        </div>
        <div>
          <label for="ohm-current" class="mb-1 block text-sm font-semibold text-blue-600 dark:text-blue-400">
            Current (I) — Amps
          </label>
          <input
            type="number"
            id="ohm-current"
            name="current"
            min="0"
            step="any"
            placeholder="e.g. 2"
            class="w-full rounded-lg border border-blue-300 bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-blue-400"
          />
        </div>
        <div>
          <label for="ohm-resistance" class="mb-1 block text-sm font-semibold text-orange-500 dark:text-orange-400">
            Resistance (R) — Ohms
          </label>
          <input
            type="number"
            id="ohm-resistance"
            name="resistance"
            min="0"
            step="any"
            placeholder="e.g. 6"
            class="w-full rounded-lg border border-orange-300 bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-orange-400"
          />
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button
          type="submit"
          class="rounded-lg bg-[var(--color-voltage)] px-5 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[var(--color-voltage)] focus:ring-offset-2"
        >
          Calculate
        </button>
        <button
          type="reset"
          class="rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface-hover)] focus:outline-none focus:ring-2 focus:ring-[var(--color-border)]"
        >
          Clear
        </button>
      </div>
    </fieldset>

    <div
      id="ohms-result"
      class="hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-sm"
      aria-live="polite"
      role="status"
    ></div>
  </form>
</div>

<script>
  (function () {
    const form = document.getElementById('ohms-calc-form') as HTMLFormElement | null;
    const resultEl = document.getElementById('ohms-result');
    if (!form || !resultEl) return;

    function round(n: number): string {
      return parseFloat(n.toFixed(4)).toString();
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const vEl = form.querySelector<HTMLInputElement>('#ohm-voltage');
      const iEl = form.querySelector<HTMLInputElement>('#ohm-current');
      const rEl = form.querySelector<HTMLInputElement>('#ohm-resistance');
      if (!vEl || !iEl || !rEl) return;

      const v = vEl.value ? parseFloat(vEl.value) : NaN;
      const i = iEl.value ? parseFloat(iEl.value) : NaN;
      const r = rEl.value ? parseFloat(rEl.value) : NaN;

      const filled = [!isNaN(v), !isNaN(i), !isNaN(r)].filter(Boolean).length;

      resultEl.classList.remove('hidden');

      if (filled < 2) {
        resultEl.innerHTML = '<span class="text-red-600">Please fill in at least two values.</span>';
        return;
      }

      // Validate positive
      if ((!isNaN(v) && v < 0) || (!isNaN(i) && i < 0) || (!isNaN(r) && r < 0)) {
        resultEl.innerHTML = '<span class="text-red-600">Values must be positive numbers.</span>';
        return;
      }

      let html = '';
      if (isNaN(v) && !isNaN(i) && !isNaN(r)) {
        const result = i * r;
        vEl.value = round(result);
        html = `<strong class="text-red-600">V</strong> = <strong class="text-blue-600">I</strong> × <strong class="text-orange-500">R</strong> = ${round(i)}A × ${round(r)}Ω = <strong class="text-red-600">${round(result)}V</strong>`;
      } else if (isNaN(i) && !isNaN(v) && !isNaN(r)) {
        if (r === 0) { resultEl.innerHTML = '<span class="text-red-600">Resistance cannot be zero when solving for current.</span>'; return; }
        const result = v / r;
        iEl.value = round(result);
        html = `<strong class="text-blue-600">I</strong> = <strong class="text-red-600">V</strong> ÷ <strong class="text-orange-500">R</strong> = ${round(v)}V ÷ ${round(r)}Ω = <strong class="text-blue-600">${round(result)}A</strong>`;
      } else if (isNaN(r) && !isNaN(v) && !isNaN(i)) {
        if (i === 0) { resultEl.innerHTML = '<span class="text-red-600">Current cannot be zero when solving for resistance.</span>'; return; }
        const result = v / i;
        rEl.value = round(result);
        html = `<strong class="text-orange-500">R</strong> = <strong class="text-red-600">V</strong> ÷ <strong class="text-blue-600">I</strong> = ${round(v)}V ÷ ${round(i)}A = <strong class="text-orange-500">${round(result)}Ω</strong>`;
      } else {
        // All three filled — verify
        const expectedV = i * r;
        const matches = Math.abs(v - expectedV) < 0.01;
        html = matches
          ? `✓ All values are consistent: ${round(v)}V = ${round(i)}A × ${round(r)}Ω`
          : `⚠ Values are inconsistent. V should be ${round(expectedV)}V (got ${round(v)}V). Clear one field to recalculate.`;
      }
      resultEl.innerHTML = html;
    });

    form.addEventListener('reset', function () {
      resultEl.classList.add('hidden');
      resultEl.innerHTML = '';
    });
  })();
</script>
