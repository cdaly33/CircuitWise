---
interface Variable {
  symbol: string;
  name: string;
  unit: string;
  color?: string;
}

interface Props {
  formula: string;
  variables: Variable[];
  example?: string;
}

const { formula, variables, example } = Astro.props;

const colorMap: Record<string, string> = {
  voltage: 'text-voltage',
  current: 'text-current',
  resistance: 'text-resistance',
  power: 'text-power',
  safety: 'text-safety',
  ground: 'text-ground',
};

function getColorClass(color?: string): string {
  if (!color) return 'text-[var(--color-text)]';
  return colorMap[color] ?? 'text-[var(--color-text)]';
}
---

<div class="my-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5">
  <!-- Formula display -->
  <div
    class="mb-4 rounded-md bg-[var(--color-bg)] p-4 text-center font-mono text-2xl font-bold tracking-wide text-[var(--color-text)]"
    role="math"
    aria-label={`Formula: ${formula}`}
  >
    {formula}
  </div>

  <!-- Variable legend -->
  <div class="mb-4 space-y-1.5">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
      Variables
    </h4>
    <ul class="space-y-1">
      {variables.map((v) => (
        <li class="flex items-baseline gap-2 text-sm">
          <span class={`font-mono font-bold ${getColorClass(v.color)}`}>{v.symbol}</span>
          <span class="text-[var(--color-text)]">
            = {v.name}
            <span class="text-[var(--color-text-muted)]">({v.unit})</span>
          </span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Optional worked example -->
  {example && (
    <div class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] p-3">
      <h4 class="mb-1 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
        Example
      </h4>
      <p class="text-sm leading-relaxed text-[var(--color-text)]">{example}</p>
    </div>
  )}
</div>
