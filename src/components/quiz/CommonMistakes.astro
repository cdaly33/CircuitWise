---
/**
 * CommonMistakes — displays a list of common mistakes after answer submission.
 * Renders nothing if no mistakes are provided.
 */
interface Props {
  mistakes?: string[];
}

const { mistakes } = Astro.props;
const hasMistakes = mistakes && mistakes.length > 0;
---

{hasMistakes && (
  <div class="quiz-common-mistakes mt-4 hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-4">
    <h4 class="mb-2 flex items-center gap-2 text-sm font-bold text-[var(--color-text)]">
      <span aria-hidden="true">⚠️</span>
      Common Mistakes
    </h4>
    <ul class="list-disc space-y-1 pl-5">
      {mistakes!.map((mistake) => (
        <li class="text-sm leading-relaxed text-[var(--color-text-muted)]">{mistake}</li>
      ))}
    </ul>
  </div>
)}
