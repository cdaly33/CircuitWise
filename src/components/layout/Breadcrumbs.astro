---
interface Props {
  segments: Array<{ label: string; href: string }>;
}

const { segments } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-[var(--color-text-muted)]">
  <ol class="flex flex-wrap items-center gap-1">
    {segments.map((segment, index) => {
      const isLast = index === segments.length - 1;
      return (
        <li class="flex items-center gap-1">
          {index > 0 && <span aria-hidden="true" class="select-none">›</span>}
          {isLast ? (
            <span aria-current="page" class="font-medium text-[var(--color-text)]">
              {segment.label}
            </span>
          ) : (
            <a
              href={segment.href}
              class="hover:text-[var(--color-text)] transition-colors underline-offset-2 hover:underline rounded focus-visible:ring-2 focus-visible:ring-[var(--color-current)] focus-visible:ring-offset-2 focus-visible:outline-none"
            >
              {segment.label}
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>
