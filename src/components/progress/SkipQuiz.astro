---
/**
 * SkipQuiz — Stage skip quiz component (stub).
 * Full interactive quiz implementation will be added in Phase 10.
 */
interface Props {
  stageSlug: string;
  stageNumber: number;
}

const { stageSlug, stageNumber } = Astro.props;
---

<details
  class="my-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)]"
  data-stage-slug={stageSlug}
  data-stage-number={stageNumber}
>
  <summary class="cursor-pointer px-5 py-3 font-semibold text-[var(--color-text)] hover:bg-[var(--color-bg)]">
    🎓 Test Your Knowledge — Skip This Stage
  </summary>
  <div class="px-5 pb-4 pt-2 text-sm text-[var(--color-text-muted)]">
    <p>Quiz coming soon. For now, proceed through the lessons.</p>
  </div>
</details>
