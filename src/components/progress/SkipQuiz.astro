---
/**
 * SkipQuiz — interactive quiz to let learners skip a stage.
 * Checks answers client-side; marks stage skipped in localStorage on pass.
 */
interface QuizQuestion {
  question: string;
  options: string[];
  correctIndex: number;
  explanation: string;
}

interface Props {
  stageSlug: string;
  stageNumber: number;
  questions?: QuizQuestion[];
  passingScore?: number;
}

const { stageSlug, stageNumber, questions = [], passingScore = 0 } = Astro.props;
const quizId = `skip-quiz-${stageSlug}`;
const hasQuestions = questions.length > 0;
const effectivePassingScore = passingScore || Math.ceil(questions.length * 0.7);
---

<details
  class="my-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)]"
  data-stage-slug={stageSlug}
  data-stage-number={stageNumber}
  id={quizId}
>
  <summary class="cursor-pointer px-5 py-3 font-semibold text-[var(--color-text)] hover:bg-[var(--color-bg)]">
    🧪 Test Your Knowledge — Skip This Stage
  </summary>

  <div class="px-5 pb-5 pt-2">
    {!hasQuestions ? (
      <p class="text-sm text-[var(--color-text-muted)]">Quiz coming soon. For now, proceed through the lessons.</p>
    ) : (
      <Fragment>
        <noscript>
          <p class="text-sm text-[var(--color-text-muted)]">
            JavaScript is required to take this quiz. All lesson content is still accessible without it.
          </p>
        </noscript>

        <form id={`${quizId}-form`} class="quiz-form space-y-6" novalidate>
          <p class="text-sm text-[var(--color-text-muted)]">
            Answer the questions below. Score at least {effectivePassingScore} out of {questions.length} to skip this stage.
          </p>

      {questions.map((q, qi) => (
        <fieldset class="rounded-lg border border-[var(--color-border)] p-4">
          <legend class="px-2 font-semibold text-[var(--color-text)]">
            {qi + 1}. {q.question}
          </legend>
          <div class="mt-2 space-y-2">
            {q.options.map((opt, oi) => (
              <label class="flex items-start gap-2 text-sm cursor-pointer">
                <input
                  type="radio"
                  name={`${quizId}-q${qi}`}
                  value={String(oi)}
                  class="mt-0.5 accent-[var(--color-voltage)]"
                  required
                />
                <span>{opt}</span>
              </label>
            ))}
          </div>
          <p
            class="quiz-explanation mt-2 hidden rounded bg-[var(--color-surface)] p-2 text-sm"
            data-explanation={q.explanation}
            data-correct={String(q.correctIndex)}
          ></p>
        </fieldset>
      ))}

      <button
        type="submit"
        class="rounded-lg bg-[var(--color-voltage)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[var(--color-voltage)] focus:ring-offset-2"
      >
        Submit Answers
      </button>

      <div
        id={`${quizId}-result`}
        class="hidden rounded-lg p-4 text-sm"
        aria-live="polite"
        role="status"
      ></div>
    </form>
      </Fragment>
    )}
  </div>
</details>

<script define:vars={{ quizId, stageNumber, passingScore: effectivePassingScore, questionCount: questions.length }}>
  (function () {
    const STORAGE_KEY = 'circuit-wise-progress';
    const form = document.getElementById(quizId + '-form');
    const resultEl = document.getElementById(quizId + '-result');
    if (!form || !resultEl) return;

    function getState() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : { completedLessons: [], completedStages: [], skippedStages: [], currentLesson: null };
      } catch {
        return { completedLessons: [], completedStages: [], skippedStages: [], currentLesson: null };
      }
    }

    function saveState(s) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var score = 0;
      var explanations = form.querySelectorAll('.quiz-explanation');

      for (var i = 0; i < questionCount; i++) {
        var selected = form.querySelector('input[name="' + quizId + '-q' + i + '"]:checked');
        var expEl = explanations[i];
        var correct = parseInt(expEl.dataset.correct, 10);

        expEl.classList.remove('hidden', 'border-green-500', 'border-red-500', 'border-l-4');

        if (selected && parseInt(selected.value, 10) === correct) {
          score++;
          expEl.classList.add('border-l-4', 'border-green-500');
          expEl.textContent = '✓ Correct — ' + expEl.dataset.explanation;
        } else {
          expEl.classList.add('border-l-4', 'border-red-500');
          expEl.textContent = '✗ Incorrect — ' + expEl.dataset.explanation;
        }
      }

      resultEl.classList.remove('hidden', 'bg-green-100', 'bg-red-100', 'text-green-800', 'text-red-800',
        'dark:bg-green-900/30', 'dark:bg-red-900/30', 'dark:text-green-300', 'dark:text-red-300');

      if (score >= passingScore) {
        resultEl.classList.add('bg-green-100', 'text-green-800', 'dark:bg-green-900/30', 'dark:text-green-300');
        resultEl.textContent = '🎉 You scored ' + score + '/' + questionCount + '! Stage ' + stageNumber + ' marked as skipped.';
        var s = getState();
        if (!s.skippedStages.includes(stageNumber)) {
          s.skippedStages.push(stageNumber);
        }
        if (!s.completedStages.includes(stageNumber)) {
          s.completedStages.push(stageNumber);
        }
        saveState(s);

        // Disable form after pass
        var inputs = form.querySelectorAll('input, button[type="submit"]');
        for (var j = 0; j < inputs.length; j++) inputs[j].disabled = true;
      } else {
        resultEl.classList.add('bg-red-100', 'text-red-800', 'dark:bg-red-900/30', 'dark:text-red-300');
        resultEl.textContent = 'You scored ' + score + '/' + questionCount + '. You need at least ' + passingScore + ' to skip. Review the incorrect answers and try again, or work through the lessons.';
      }
    });
  })();
</script>
